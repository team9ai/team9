{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Team9",
  "version": "0.1.0",
  "identifier": "com.weight-wave.team9-client",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Team9",
        "width": 1280,
        "height": 800,
        "minWidth": 375,
        "minHeight": 667,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "contentProtected": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["team9"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ahandd"],
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 920,
          "height": 640
        },
        "appPosition": {
          "x": 250,
          "y": 280
        },
        "applicationFolderPosition": {
          "x": 670,
          "y": 280
        }
      }
    }
  }
}
