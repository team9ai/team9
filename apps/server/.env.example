# Server Configuration
GATEWAY_PORT=3000
IM_WORKER_PORT=3001

# IM Worker gRPC Configuration (for Railway deployment, use: im-worker.railway.internal:3001)
IM_WORKER_GRPC_URL=localhost:3001

# Edition Configuration (community | enterprise)
EDITION=community

# Enterprise License Key (required for enterprise edition)
# LICENSE_KEY=your-license-key

# PostgreSQL Configuration (used by docker-compose and application)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=team9
DB_PORT=5432

# Redis Configuration 
REDIS_PASSWORD=
REDIS_PORT=6379

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google (Gemini) Configuration
GOOGLE_API_KEY=your-google-api-key

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=AI Service

# JWT Configuration (ES256 - ECDSA P-256)
# Generate keys with: openssl ecparam -name prime256v1 -genkey -noout -out private.pem
#                     openssl ec -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END EC PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
JWT_REFRESH_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
YOUR_REFRESH_PRIVATE_KEY_HERE
-----END EC PRIVATE KEY-----"
JWT_REFRESH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_REFRESH_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
INTERNAL_AUTH_VALIDATION_TOKEN=your-internal-validation-bearer-secret

# System Bot Configuration (Moltbot)
# When enabled, this bot account will be automatically added to all new workspaces
# Users can then interact with the bot via the Moltbot integration
SYSTEM_BOT_ENABLED=true
SYSTEM_BOT_EMAIL=
SYSTEM_BOT_USERNAME=moltbot
SYSTEM_BOT_PASSWORD=your-secure-bot-password
SYSTEM_BOT_DISPLAY_NAME=Moltbot

# Claw Hive Integration (optional - base model staff disabled when not set)
# CLAW_HIVE_API_URL=http://localhost:4100
# CLAW_HIVE_AUTH_TOKEN=your-pre-shared-key

# Sentry Configuration (optional - monitoring disabled when not set)
# Each service can have its own DSN, or share one via SENTRY_DSN
# SENTRY_GATEWAY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
# SENTRY_IM_WORKER_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx  # fallback for all services

# PostHog (optional - SDK initialized but no business events are emitted until code calls the service)
# POSTHOG_PROJECT_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_FEATURE_FLAGS_SECURE_API_KEY=phs_xxx

# OpenTelemetry / Grafana Cloud (optional - observability disabled when OTEL_ENABLED is not 'true')
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_CLOUD_TOKEN=  # Base64 encoded instanceId:apiKey
# OTEL_SERVICE_NAME=gateway  # Set to 'im-worker' for the IM Worker service

# Capability Hub (LLM proxy with billing, deep-research relay)
# CAPABILITY_HUB_URL=http://localhost:4000
# Shared service key sent as `x-service-key` when the gateway calls the hub
# on behalf of an authenticated user (deep-research). Must match the hub's
# SERVICE_API_KEY. >=16 chars.
# CAPABILITY_HUB_API_KEY=

# Billing Hub (required for subscription management)
# BILLING_HUB_BASE_URL=http://localhost:4001
# BILLING_HUB_SERVICE_KEY=replace-with-team9-service-key

# Web Push (optional — push notifications disabled when not set)
# Generate VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@team9.ai

# Cloudflare Turnstile (application-layer CAPTCHA)
# Required in production. Leave blank in local dev to skip verification,
# or set to the always-pass test secret `1x0000000000000000000000000000000AA`.
CLOUDFLARE_TURNSTILE_SECRET_KEY=
