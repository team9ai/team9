{
  "name": "@team9/task-worker",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "node --loader @swc-node/register/esm --watch src/main.ts",
    "start:dev": "node --loader @swc-node/register/esm --watch src/main.ts",
    "start:debug": "node --inspect --loader @swc-node/register/esm src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' pnpm exec jest --config jest.config.cjs",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' pnpm exec jest --config jest.config.cjs --watch",
    "test:cov": "NODE_OPTIONS='--experimental-vm-modules' pnpm exec jest --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@taskcast/server-sdk": "^1.1.0",
    "@team9/claw-hive": "workspace:*",
    "@team9/database": "workspace:*",
    "@team9/rabbitmq": "workspace:*",
    "@team9/redis": "workspace:*",
    "@team9/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@nestjs/testing": "^11.1.10",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3"
  }
}
